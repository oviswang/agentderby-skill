  <main class="main">
    <div class="content-wrap" id="contentWrap">
      <section class="hero">
        <div class="card">
          <div class="kicker">Hook me to bots</div>
          <h1 class="h1">A simpler way to use OpenClaw.</h1>
          <p class="p">What bothook does is simple: it sets up the OpenClaw bot for you and brings it directly into the chat apps you already use.</p>
          <p class="p">No signup. No setup. No technical knowledge required.</p>

          <div class="ctaRow">
            <a class="cta primary" href="#" id="ctaPrimary">Get started</a>
            <a class="cta ghost" href="#" id="ctaSecondary">Contact</a>
          </div>

          <p class="p" style="margin-top:14px; font-size:13px;">The website is only for getting started, payment, and checking status. Once the bot is ready, you rarely need to come back.</p>
        </div>
        <div>
          <img class="logoLarge" src="/assets/logo.jpg" alt="BOTHook" />
        </div>
      </section>

      <section class="grid2">
        <div class="card">
          <h2 class="h2">What is bothook.me?</h2>
          <p class="p">bothook offers a simpler way to use OpenClaw. It doesn’t change OpenClaw, and it doesn’t ask you to install or maintain anything yourself.</p>
          <p class="p">The bot appears directly in the chat apps you already use. All you need to do is start chatting.</p>
        </div>
        <div class="card">
          <h2 class="h2">What bothook actually does</h2>
          <p class="p">bothook doesn’t create a new bot. And it doesn’t add another complicated layer on top of OpenClaw.</p>
          <p class="p"><strong>It does one simple thing:</strong> it sets up OpenClaw for you and brings it directly into the chat apps you already use.</p>
        </div>
      </section>

      <section class="grid2">
        <div class="card">
          <h2 class="h2">What using it feels like</h2>
          <ul class="list">
            <li>You don’t use a bot inside a website.</li>
            <li>You don’t need to learn a new interface.</li>
            <li>Open your chat app as usual.</li>
            <li>Start a conversation.</li>
            <li>You’re already using OpenClaw.</li>
          </ul>
          <p class="p" style="margin-top:12px;">You can talk to it on WhatsApp, Telegram, or Discord — right where you already are.</p>
        </div>
        <div class="card">
          <h2 class="h2">Who it’s for (and not for)</h2>
          <div class="split">
            <div>
              <div class="label">For you if</div>
              <ul class="list">
                <li>you want to use OpenClaw, not learn how to install it</li>
                <li>you prefer getting things done in chat apps</li>
                <li>you care about using the bot, not running it</li>
              </ul>
            </div>
            <div>
              <div class="label">Not a good fit if</div>
              <ul class="list">
                <li>you want full control over installation and runtime</li>
                <li>you need deep low-level customization</li>
                <li>you enjoy setting up, maintaining, and debugging systems</li>
              </ul>
            </div>
          </div>
          <p class="p" style="margin-top:12px;"><strong>One-line boundary:</strong> bothook is for people who want to use a bot, not for people who want to build one.</p>
        </div>
      </section>

      <section class="card" style="margin-top:18px;">
        <h2 class="h2">FAQ</h2>
        <details class="faq">
          <summary>Do I need to create an account?</summary>
          <div>No. There’s no signup and no login.</div>
        </details>
        <details class="faq">
          <summary>Do I need to install or configure anything?</summary>
          <div>No. bothook takes care of setting up OpenClaw for you.</div>
        </details>
        <details class="faq">
          <summary>Where do I use the bot?</summary>
          <div>In the chat apps you already use, such as WhatsApp, Telegram, or Discord.</div>
        </details>
        <details class="faq">
          <summary>Do I need to keep coming back to the website?</summary>
          <div>No. The website is only for getting started, payment, and checking status or billing.</div>
        </details>
        <details class="faq">
          <summary>What happens if I don’t renew?</summary>
          <div>The bot will stop running after it expires. No extra action is required from you.</div>
        </details>
        <details class="faq">
          <summary>Does bothook change OpenClaw?</summary>
          <div>No. bothook simply makes OpenClaw easier to start using.</div>
        </details>
      </section>

      <section class="card" style="margin-top:18px;">
        <h2 class="h2">Summary</h2>
        <p class="p">bothook is a simpler way to use OpenClaw. It doesn’t change how OpenClaw works — it just brings it directly to you.</p>
        <p class="p">You don’t need to understand how it runs. You only need to start chatting.</p>
      </section>
    </div>
  </main>

  <footer class="footer">
    © <span id="year"></span> BOTHook. All rights reserved.
  </footer>

  <script>
    // Minimal scaffolding for the “Apple-grade” language switch spec on a static site.
    // - 150ms fade-out then URL switch; 150ms fade-in on load.
    const wrap = document.getElementById('contentWrap');
    const year = document.getElementById('year');
    year.textContent = new Date().getFullYear();

    // Fade-in on mount
    wrap.style.opacity = '0';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => { wrap.style.opacity = '1'; });
    });

    // Locale list (placeholder). We'll replace with the real 12 locales later.
    const locales = [
      { code: 'en', native: 'English', en: 'English' },
      { code: 'ja', native: '日本語', en: 'Japanese' },
      { code: 'zh-Hans', native: '中文（简体）', en: 'Simplified' },
      { code: 'zh-Hant', native: '繁體中文', en: 'Traditional' },
      { code: 'ar', native: 'العربية', en: 'Arabic', rtl: true },
    ];

    function currentLocale(){
      const p = location.pathname;
      // expected future: /{locale}/
      const m = p.match(/^\/([^\/]+)\//);
      return m ? m[1] : 'en';
    }

    function setDirForLocale(code){
      document.documentElement.dir = (code === 'ar') ? 'rtl' : 'ltr';
    }

    setDirForLocale(currentLocale());

    // Language switcher (minimal). We'll make it Apple-like with a dropdown panel later.
    const btn = document.getElementById('langBtn');
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      // For now, cycle locales to demonstrate fade behavior.
      const cur = currentLocale();
      const idx = locales.findIndex(l => l.code === cur);
      const next = locales[(idx + 1) % locales.length].code;
      // 150ms fade-out
      wrap.classList.add('is-transitioning');
      setTimeout(() => {
        const url = (next === 'en') ? '/' : `/${next}/`;
        location.href = url;
      }, 150);
    });

    // Browser language suggestion banner (first visit only, minimal).
    const dismissed = localStorage.getItem('bothook_lang_banner_dismissed');
    if (!dismissed) {
      const navLang = (navigator.language || 'en').toLowerCase();
      const supported = locales.map(l => l.code.toLowerCase());
      const best = supported.find(c => navLang.startsWith(c.toLowerCase())) || null;
      const cur = currentLocale().toLowerCase();
      if (best && best !== cur) {
        const banner = document.getElementById('langBanner');
        const text = document.getElementById('langBannerText');
        const sw = document.getElementById('langBannerSwitch');
        const dis = document.getElementById('langBannerDismiss');
        const label = locales.find(l => l.code.toLowerCase() === best)?.native || best;
        text.textContent = `View this page in ${label}?`;
        banner.style.display = 'block';
        sw.onclick = () => { localStorage.setItem('bothook_lang_banner_dismissed','1'); location.href = (best==='en')?'/':`/${best}/`; };
        dis.onclick = () => { localStorage.setItem('bothook_lang_banner_dismissed','1'); banner.style.display = 'none'; };
      }
    }
  </script>
</body>
</html>
