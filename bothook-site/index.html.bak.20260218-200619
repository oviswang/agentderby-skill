  <link rel="canonical" href="https://bothook.me/" />
  <link rel="alternate" hreflang="en" href="https://bothook.me/" />
  <link rel="alternate" hreflang="zh" href="https://bothook.me/zh/" />
</head>
<body>
  <div class="banner" id="langBanner" aria-live="polite">
    <div class="inner card" style="padding:8px 10px;">
      <div id="langBannerText">View this page in another language?</div>
      <div style="display:flex; gap:8px; align-items:center;">
        <button id="langBannerSwitch" type="button">Switch</button>
        <button id="langBannerDismiss" type="button">Not now</button>
      </div>
    </div>
  </div>

  <header class="header">
    <a class="brand" href="/" aria-label="BOTHook home">
      <img src="/assets/logo.jpg" alt="BOTHook logo" />
      <strong>BOTHook</strong>
    </a>
    <div class="langWrap">
      <a class="langbtn" href="#" id="langBtn" aria-haspopup="menu" aria-expanded="false">
        <span aria-hidden="true">🌐</span>
        <span id="langLabel">English</span>
      </a>
      <div class="langPanel" id="langPanel" role="menu" aria-label="Language">
        <a class="langItem" href="/" data-locale="en" role="menuitem"><span class="native">English</span><span class="en">English</span></a>
        <a class="langItem" href="/zh/" data-locale="zh" role="menuitem"><span class="native">中文</span><span class="en">Chinese</span></a>
      </div>
    </div>
  </header>

  <main class="main">
    <div class="content-wrap" id="contentWrap">
      <section class="hero">
        <div class="card">
          <div class="kicker">Hook me to bots</div>
          <h1 class="h1">A simpler way to use OpenClaw.</h1>
          <p class="p">What bothook does is simple: it sets up the <a href="https://openclaw.ai" target="_blank" rel="noopener noreferrer">OpenClaw</a> bot for you and brings it directly into the chat apps you already use.</p>
          <p class="p">No signup. No setup. No technical knowledge required.</p>

          <div class="ctaRow">
            <a class="cta primary wide" href="https://p.bothook.me/" id="ctaPrimary">Get started</a>
          </div>

          <p class="p" style="margin-top:14px; font-size:13px;">The website is only for getting started, payment, and checking status. Once the bot is ready, you rarely need to come back.</p>
        </div>
        <div class="card" style="padding:0; display:flex;">
          <div class="demoFrame" aria-label="WhatsApp linking animation">
            <iframe class="demoIframe" src="/assets/wa-linking-demo.html?lang=en" title="WhatsApp device linking demo" loading="lazy" referrerpolicy="no-referrer"></iframe>
          </div>
        </div>
      </section>

      <section class="grid2">
        <div class="card">
          <h2 class="h2">What is bothook.me?</h2>
          <p class="p">bothook offers a simpler way to use OpenClaw. It doesn’t change OpenClaw, and it doesn’t ask you to install or maintain anything yourself.</p>
          <p class="p">The bot appears directly in the chat apps you already use. All you need to do is start chatting.</p>
        </div>
        <div class="card">
          <h2 class="h2">What bothook actually does</h2>
          <p class="p">bothook doesn’t create a new bot. And it doesn’t add another complicated layer on top of OpenClaw.</p>
          <p class="p"><strong>It does one simple thing:</strong> it sets up OpenClaw for you and brings it directly into the chat apps you already use.</p>
        </div>
      </section>

      <section class="grid2">
        <div class="card">
          <h2 class="h2">What using it feels like</h2>
          <ul class="list">
            <li>You don’t use a bot inside a website.</li>
            <li>You don’t need to learn a new interface.</li>
            <li>Open your chat app as usual.</li>
            <li>Start a conversation.</li>
            <li>You’re already using OpenClaw.</li>
          </ul>
          <p class="p" style="margin-top:12px;">You can talk to it on WhatsApp, Telegram, or Discord — right where you already are.</p>
        </div>
        <div class="card">
          <h2 class="h2">Who it’s for (and not for)</h2>
          <div class="split">
            <div>
              <div class="label">For you if</div>
              <ul class="list">
                <li>you want to use OpenClaw, not learn how to install it</li>
                <li>you prefer getting things done in chat apps</li>
                <li>you care about using the bot, not running it</li>
              </ul>
            </div>
            <div>
              <div class="label">Not a good fit if</div>
              <ul class="list">
                <li>you want full control over installation and runtime</li>
                <li>you need deep low-level customization</li>
                <li>you enjoy setting up, maintaining, and debugging systems</li>
              </ul>
            </div>
          </div>
          <p class="p" style="margin-top:12px;"><strong>One-line boundary:</strong> bothook is for people who want to use a bot, not for people who want to build one.</p>
        </div>
      </section>

      <section class="card" style="margin-top:18px;">
        <h2 class="h2">FAQ</h2>
        <details class="faq">
          <summary>Do I need to create an account?</summary>
          <div>No. There’s no signup and no login.</div>
        </details>
        <details class="faq">
          <summary>Do I need to install or configure anything?</summary>
          <div>No. bothook takes care of setting up OpenClaw for you.</div>
        </details>
        <details class="faq">
          <summary>Where do I use the bot?</summary>
          <div>In the chat apps you already use, such as WhatsApp, Telegram, or Discord.</div>
        </details>
        <details class="faq">
          <summary>Do I need to keep coming back to the website?</summary>
          <div>No. The website is only for getting started, payment, and checking status or billing.</div>
        </details>
        <details class="faq">
          <summary>What happens if I don’t renew?</summary>
          <div>The bot will stop running after it expires. No extra action is required from you.</div>
        </details>
        <details class="faq">
          <summary>Does bothook change OpenClaw?</summary>
          <div>No. bothook simply makes OpenClaw easier to start using.</div>
        </details>
      </section>

      <section class="card" style="margin-top:18px;">
        <h2 class="h2">Summary</h2>
        <p class="p">bothook is a simpler way to use OpenClaw. It doesn’t change how OpenClaw works — it just brings it directly to you.</p>
        <p class="p">You don’t need to understand how it runs. You only need to start chatting.</p>
      </section>
    </div>
  </main>

  <footer class="footer">
    <div class="footerRow">
      <div>© <span id="year"></span> BOTHook.</div>
      <nav class="footerLinks" aria-label="Footer">
        <a href="/contact.html">Contact</a>
        <span class="dot">·</span>
        <a href="/terms.html">Terms</a>
        <span class="dot">·</span>
        <a href="/privacy.html">Privacy</a>
      </nav>
    </div>
  </footer>

  <script>
    // Minimal scaffolding for the “Apple-grade” language switch spec on a static site.
    // - 150ms fade-out then URL switch; 150ms fade-in on load.
    const wrap = document.getElementById('contentWrap');
    const year = document.getElementById('year');
    year.textContent = new Date().getFullYear();

    // Fade-in on mount
    wrap.style.opacity = '0';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => { wrap.style.opacity = '1'; });
    });

    function currentLocale(){
      const p = location.pathname;
      return p.startsWith('/zh/') ? 'zh' : 'en';
    }

    function openPanel(open){
      const p = document.getElementById('langPanel');
      const b = document.getElementById('langBtn');
      if (!p) return;
      if (open) { p.classList.add('open'); b.setAttribute('aria-expanded','true'); }
      else { p.classList.remove('open'); b.setAttribute('aria-expanded','false'); }
    }

    document.getElementById('langBtn').addEventListener('click', (e) => {
      e.preventDefault();
      const p = document.getElementById('langPanel');
      openPanel(!p.classList.contains('open'));
    });

    // Fade transition on language switch
    document.querySelectorAll('.langItem').forEach(a => {
      a.addEventListener('click', (e) => {
        const href = a.getAttribute('href');
        if (!href) return;
        e.preventDefault();
        wrap.classList.add('is-transitioning');
        setTimeout(() => { location.href = href; }, 150);
      });
    });

    document.addEventListener('click', (e) => {
      if (!e.target.closest('.langWrap')) openPanel(false);
    });

    // Locale auto-follow (requested):
    // - If we can detect browser language, we pick it.
    // - If not, default is English (/).
    // - To avoid trapping users, we allow an opt-out flag.
    const dismissed = localStorage.getItem('bothook_lang_banner_dismissed');
    const navLang = (navigator.language || '').toLowerCase();
    const cur = currentLocale();
    const best = navLang.startsWith('zh') ? 'zh' : (navLang.startsWith('en') ? 'en' : 'en');

    // Auto-redirect only from the root EN page and only if user hasn't dismissed.
    if (!dismissed && cur === 'en' && best === 'zh' && location.pathname === '/') {
      // small delay prevents white flash on some mobile browsers
      wrap.classList.add('is-transitioning');
      setTimeout(() => { location.replace('/zh/'); }, 150);
    }

    // Keep the refined banner as an explicit control (first visit only).
    if (!dismissed && best !== cur) {
      const banner = document.getElementById('langBanner');
      const text = document.getElementById('langBannerText');
      const sw = document.getElementById('langBannerSwitch');
      const dis = document.getElementById('langBannerDismiss');
      text.textContent = (best === 'zh') ? '查看中文版本？' : 'View this page in English?';
      banner.style.display = 'block';
      sw.onclick = () => {
        localStorage.setItem('bothook_lang_banner_dismissed','1');
        location.href = (best === 'zh') ? '/zh/' : '/';
      };
      dis.onclick = () => { localStorage.setItem('bothook_lang_banner_dismissed','1'); banner.style.display = 'none'; };
    }
  </script>
</body>
</html>
